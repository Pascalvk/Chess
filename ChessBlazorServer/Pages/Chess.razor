    public bool isPromotionPending = false;
    private TaskCompletionSource<bool> ConfirmationTaskSource;
    char promotionChoiceChar = 'Q';

    (int, int) currentlyDraggingOverSquare = (-1, -1);
    (int, int) currentlyDraggingPiecePos = (-1, -1);
    string moveToSquare = "";
    string cursorSybmbol = "";
    string visibilityPiece = "";
 
    bool isDragging = false;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        gameLogic = new GameLogic(board);

