    public void HandleClickQueen(char choice)
    {
        promotionChoiceChar = choice;
        ConfirmationTaskSource?.SetResult(true);
    }

    public void HandleClickRook(char choice)
    {
        promotionChoiceChar = choice;
        ConfirmationTaskSource?.SetResult(true);
    }

    public void HandleClickBishop(char choice)
    {
        promotionChoiceChar = choice;
        ConfirmationTaskSource?.SetResult(true);
    }

    public void HandleClickKnight(char choice)
    {
        promotionChoiceChar = choice;
        ConfirmationTaskSource?.SetResult(true);
    }


    public async Task OnDragStart((int, int) id)
    {
        isDragging = true;
        currentlyDraggingPiecePos = id;
        ChessPiece clickedPiece = board.GetPieceAt(id.Item1, id.Item2);

        if (!isPromotionPending)
        {

            // Select a piece
            if (!isSelected)
            {
                SelectPiece(id);

                if (selectedPiece != board.EmptyChessPiece && selectedPiece.Color == gameLogic.currentPlayer)
                {
                    isSelected = true;
                }
            }
            // Change to other piece selection or move piece
            else if (isSelected && clickedPiece.Color == gameLogic.currentPlayer)
            {
                SelectPiece(id);

            }
        }
    }

    public void OnDragOver((int, int) id)
    {
        currentlyDraggingOverSquare = id;
        
    }

    public async Task OnDragEnd()
    {
        
        if (selectedPiece.MoveList.Contains(currentlyDraggingOverSquare))
        {
            await MoveLogic(currentlyDraggingOverSquare);
        }
        isDragging = false;
        currentlyDraggingOverSquare = (-1, -1);
        currentlyDraggingPiecePos = (-1, -1);
    }

    public async Task OnClick((int, int) id)
    {

        ChessPiece clickedPiece = board.GetPieceAt(id.Item1, id.Item2);

        if (!isPromotionPending)
        {

            // Select a piece
            if (!isSelected)
            {
                SelectPiece(id);

                if (selectedPiece != board.EmptyChessPiece && selectedPiece.Color == gameLogic.currentPlayer)
                {
                    isSelected = true;
                }
            }

            // Change to other piece selection or move piece
            else if (isSelected && clickedPiece.Color == gameLogic.currentPlayer)
            {
                SelectPiece(id);

            }
            else
            {
                await MoveLogic(id);
            }

        }

    }


    public void SelectPiece((int,int) id)
    {
        ChessPiece pieceAtLocation = board.GetPieceAt(id.Item1, id.Item2);
        if (pieceAtLocation != board.EmptyChessPiece && pieceAtLocation.Color == gameLogic.currentPlayer)
        {
            selectedPiece = pieceAtLocation;
            if (selectedPiece is King)
            {
                King king = selectedPiece as King;
                //king.PossibleAttackSquaresKing(board);
                king.PossibleMoves(board);
                king.PossiblePiecesToAttack(board);
            }
            else
            {
                selectedPiece.PossibleMoves(board);
                selectedPiece.KeepOrRemoveMovesForProtectingKing(board);
                selectedPiece.PossiblePiecesToAttack(board);
                selectedPiece.RemoveAttackingPiecesWhenNotInMoveList(board);
            }
        }
        else
        {
            selectedPiece = board.EmptyChessPiece;
        }
    }

    private async Task<bool> WaitForUserConfirmation()
