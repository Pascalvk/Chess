@using ChessBlazorServer.Classes
@using System.Linq;
@using System.Threading.Tasks;
@page "/chess"
@code {
    [Parameter] public bool isWhiteBottom { get; set; } = true; // Standaard is wit onderaan
}

<link href="css/chessGame.css" rel="stylesheet">
<h3>Chess</h3>

Als je dit leest werkt de link


<div class=""></div>

<div class="chess-board">
    @for (int row = 0; row < Board.BoardSize; row++)
    {
        int displayRow = isWhiteBottom ? row : Board.BoardSize - 1 - row;

        @for (int col = 0; col < Board.BoardSize; col++)
        {                 
            ChessPiece thisPiece = board.GetPieceAt(row, col);
            (int, int) id = (row, col);
            string possibleMoveDot = "";
            string backGroundSquare = "";
            string isDraggable = "false";


            if (isDragging && currentlyDraggingPiecePos == id)
            {
                visibilityPiece = "invisible";
            }
            else
            {
                visibilityPiece = "visible";
            }


            @if (thisPiece.SVGName != "")
            {
                isDraggable = "true";

            }
            if (gameLogic.currentPlayer == thisPiece.Color)
            {
                cursorSybmbol = "cursorDrag";
            }
            else
            {
                cursorSybmbol = "";
            }



            @if ((displayRow + col) % 2 == 0)
            {
                backGroundSquare = "light-square";
            }
            else
            {
                backGroundSquare = "dark-square";
            }

            @if (selectedPiece != null)
            {
                bool isAttackingPosition = selectedPiece.AttackingPieceList.Contains(id);
                bool isMovePosition = selectedPiece.MoveList.Contains(id);

                if (isAttackingPosition)
                {
                    possibleMoveDot = "TakeThisCircle";
                }
                else if (isMovePosition)
                {
                    possibleMoveDot = "PossibleMoveDot";
                }
                if (selectedPiece is Pawn && isAttackingPosition)
                {
                    possibleMoveDot = "TakeThisCircle";
                }

                if (board.IsInCheck && board.IsInCheckColor == thisPiece.Color && thisPiece.Name == "K")
                {
                    backGroundSquare = "check-square";
                }

                if (selectedPiece.Position == id || gameLogic.LastMoveFromToLocation[0] == id || gameLogic.LastMoveFromToLocation[1] == id)
                {
                    backGroundSquare = "select-square";
                }


                if (isSelected && currentlyDraggingOverSquare == id)
                {
                    moveToSquare = "MoveToSquare";
                }
                else
                {
                    moveToSquare = "";
                }
            }


            <div class="@backGroundSquare" id="@id" @ondragover="() => OnDragOver(id)">
                <div class="square @thisPiece.SVGName @cursorSybmbol @visibilityPiece"
                     draggable="@isDraggable"
                     @onclick="() => OnClick(id)"
                     @ondragstart="() => OnDragStart(id)"
                     @ondragend="() => OnDragEnd()">

                    <div class="@moveToSquare"></div>
                    <div class="@possibleMoveDot"> </div>
                </div>
                
            </div>
        }
    }
</div>

<div>@selectedPiece</div>
<div>@currentlyDraggingOverSquare</div>

<div class="chess-row">
    PositionsUnderAttack:
    @if (board != null)
    {
        //selectedPiece.FillAttackThisPiecesList(board);
        @foreach (var moves in board.UnderAttackPositions)
        {
            <div>@moves</div>
        }
    }
</div>

<div class="chess-row"> 
    (row, col) Moves: 
    @if (selectedPiece != null)
    {
        //selectedPiece.FillAttackThisPiecesList(board);
        @foreach (var moves in selectedPiece.MoveList)
        {
            <div>@moves</div>
        }
    }
</div>

<div class="chess-row">
    (row, col) AttackList:
    @if (selectedPiece != null)
    {
        //selectedPiece.FillAttackThisPiecesList(board);
        @foreach (var moves in selectedPiece.AttackList)
        {
            <div>@moves</div>
        }
    }
</div>

<div class="chess-row">
    (row, col) AttackPieces:
    @if (selectedPiece != null)
    {
        //selectedPiece.FillAttackThisPiecesList(board);
        @foreach (var moves in selectedPiece.AttackingPieceList)
        {
            <div>@moves</div>
        }
    }
</div>

<div class="chess-row">
    White King is at position:
    <div>@board.GetPosOfPiece("K", "white")  </div>
</div>

<div class="chess-row">
    CurrentPlayer: 
    <div>@gameLogic.currentPlayer </div>
    checkcolor:
    <div>@board.IsInCheckColor </div>

</div>

@if (isPromotionPending){
    <div class="chess-row">
        <button @onclick="() => HandleClickQueen('Q')">Queen</button>
        <button @onclick="() => HandleClickRook('R')">Rook</button>
        <button @onclick="() => HandleClickBishop('B')">Bishop</button>
        <button @onclick="() => HandleClickKnight('N')">Knight</button>
    </div>
}


